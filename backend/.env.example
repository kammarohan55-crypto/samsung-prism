# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change-me-in-production-use-a-64-char-random-string
JWT_EXPIRY=24h

# Database
DB_PATH=../data/itis.db

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:8788

# LLM Provider (openai | anthropic | ollama)
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Embedding
EMBEDDING_MODEL=text-embedding-3-small

# Vector Store
VECTOR_DB_PATH=../data/vectorstore

# Telemetry API Keys (Phase 5+)
GITHUB_TOKEN=
JIRA_TOKEN=
JIRA_BASE_URL=
GOOGLE_CALENDAR_CREDENTIALS=
SLACK_BOT_TOKEN=
